class Solution {
    static boolean armstrongNumber(int n) {
        // code here
        int original = n ;
        int sum = 0 ;
        while(n != 0){
           int rem = n % 10 ;
           sum += rem*rem*rem;
           n /= 10 ;
        }
        if(sum == original)return true ;
        else return false ;
    }
}
